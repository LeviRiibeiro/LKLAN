# Configuracoes LAN Manager Escolar
# Copie este arquivo para .env e ajuste os valores conforme necessario

# API e Servidor
API_HOST=0.0.0.0
API_PORT=8000

# Banco de Dados
SQLITE_PATH=./database.db

# JWT
JWT_SECRET_KEY=seu-secret-key-aleatorio-com-32-caracteres-minimo!!!
JWT_ALGORITHM=HS256

# Admin Padrão (criado ao rodar seed.py)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=Administrador

# Diretorio de Backup (criar manualmente)
BACKUP_PATH=./backups
